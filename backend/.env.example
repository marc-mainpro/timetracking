# Copiar a .env (fuera de control de versiones) y rellenar valores reales.
# Nunca commitear secretos.

# Perfil activo de Spring
SPRING_PROFILES_ACTIVE=local

# Datasource PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/timetracking
DB_USER=timetracking
DB_PASSWORD=changeme

# Seguridad / autenticacion
JWT_SECRET=replace-with-at-least-32-bytes-secret
FRONTEND_ORIGIN=http://localhost:4200
AUTH_REFRESH_COOKIE_SECURE=false
APP_REQUEST_MAX_PAYLOAD_BYTES=65536
